# Supabase (client-side + server)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# CRON (Vercel Cron Jobs)
CRON_SECRET=""

# API Interna (header x-api-secret)
API_SECRET=""

# Analista IA — Fase 2 (JLAU-571)
# "true" -> Analista escreve no CRM (nome, procedimento, sobreOPaciente, statusFunil)
#           e a tool salvar_qualificacao da Ana Julia fica inerte
# ausente/outro -> Shadow mode (so loga em analista_logs, nao escreve)
